# Copiar a .env y completar con los valores reales.
# .env está en .gitignore — NUNCA subir credenciales al repositorio.

# GeoServer (REST API)
GEOSERVER_URL=https://geoportal.ucr.ac.cr/geoserver
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=

# Servidor del geoportal (SSH/scp)
GEOPORTAL_SSH_HOST=geoportal.ucr.ac.cr
GEOPORTAL_SSH_USER=geoportal

# GeoNode (API v2) — pendiente de configurar (ver docs/geonode.md)
GEONODE_URL=https://geoportal.ucr.ac.cr
GEONODE_TOKEN=
