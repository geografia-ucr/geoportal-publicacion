                <gco:CharacterString>Pérdida y ganancia de cobertura arbórea sobre paisaje productivo de pastos en Costa Rica 2021-2022 a escala 1:10.000</gco:CharacterString>
              </cit:title>
              <cit:alternateTitle>
                <gco:CharacterString>EG-UCR_PG_CARBPAS_2021-2022_10K</gco:CharacterString>
              </cit:alternateTitle>

