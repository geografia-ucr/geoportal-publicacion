                <gco:CharacterString>Pérdida de cobertura arbórea en paisaje de café de Costa Rica 2021-2022 a escala 1:25.000</gco:CharacterString>
              </cit:title>
              <cit:alternateTitle>
                <gco:CharacterString>CR_INISEFOR-UNA_CCA_CAMBIO_2021_2022_25K</gco:CharacterString>
              </cit:alternateTitle>

